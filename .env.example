# Supabase — from supabase.com project dashboard
NEXT_PUBLIC_SUPABASE_URL= # Project URL (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Anon key (safe for browser)
SUPABASE_SERVICE_ROLE_KEY= # Secret key — server-side only, NEVER expose to browser

# OpenAI — from platform.openai.com
OPENAI_API_KEY= # Required for Codex SDK — server-side only

# Playwright E2E — optional local test account and app URL
PLAYWRIGHT_BASE_URL=http://localhost:3000 # Optional override for Playwright base URL
PLAYWRIGHT_TEST_EMAIL= # Merchant email used by Playwright E2E tests
PLAYWRIGHT_TEST_PASSWORD= # Merchant password used by Playwright E2E tests
